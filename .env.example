# Backend environment variables
DATABASE_URL=sqlite:///backend/app/database/dev.db
AUTO_CREATE_TABLES=true
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
SECRET_KEY=change-this-secret
API_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
RELOAD=false

# PostgreSQL values used when DATABASE_URL points to PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nextwin
POSTGRES_PASSWORD=nextwin
POSTGRES_DB=nextwin_db

# AI engine settings
MODEL_DIR=ai_engine/models
OLLAMA_HOST=http://localhost:11434
COPILOT_LLM_MODEL=llama3
